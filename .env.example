# Copy to .env.local and fill in. These seed the provider registry on first
# run (data/providers.json). After that, edit providers in the Settings UI.
# Delete data/providers.json to re-seed from these values.

# --- Hermes Agent (priority connection) ---------------------------------
# Hermes serves an OpenAI-compatible API. Default port is 8642, base path /v1.
# Point this at wherever your Hermes API server is reachable from this app.
HERMES_BASE_URL=http://127.0.0.1:8642/v1
# The API_SERVER_KEY you configured in Hermes (Bearer token).
HERMES_API_KEY=
# Comma-separated model ids to expose (Hermes uses "hermes-agent").
HERMES_MODELS=hermes-agent

# --- Hermes management API (control plane) ------------------------------
# Hermes' dashboard exposes /api/* endpoints (models, cron, sessions, config,
# env, MCP, webhooks, ...). The app proxies these server-side. The dashboard
# defaults to port 9119. On a loopback URL Hermes serves /api/* without auth;
# on a non-loopback URL you must supply a token.
HERMES_ADMIN_URL=http://127.0.0.1:9119
# auto | none | bearer | cookie  (auto = no auth on loopback, bearer otherwise)
HERMES_ADMIN_AUTH=auto
# Bearer token or session cookie value (only needed for non-loopback URLs).
HERMES_ADMIN_TOKEN=

# --- Ollama (optional) --------------------------------------------------
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODELS=llama3.1,qwen2.5

# --- OpenRouter (optional) ----------------------------------------------
# OPENROUTER_API_KEY=
# OPENROUTER_MODELS=openai/gpt-4o-mini,anthropic/claude-3.5-sonnet

# --- OpenAI (optional) --------------------------------------------------
# OPENAI_API_KEY=
# OPENAI_MODELS=gpt-4o-mini,gpt-4o

# --- Anthropic (optional) -----------------------------------------------
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODELS=claude-sonnet-4-6,claude-opus-4-8

# Public URL of this app (used for OpenRouter referer header).
APP_URL=http://localhost:3000
