# Copy to .env.local and fill in. Direct providers seed data/providers.json;
# the Hermes Gateway fields seed data/hermes.json. Both are first-run only —
# after that, edit everything in the Settings → Connections UI. Delete the
# matching data/*.json to re-seed from these values.

# --- Hermes Agent — the Gateway (single connection, both planes) --------
# Hermes has two planes on different ports: an OpenAI-compatible chat API
# (/v1, default :8642) and a management API (/api/*, default :9119). Both
# belong to one "Gateway" connection (data/hermes.json) — Hermes is no longer
# a generic provider in data/providers.json.

# Chat (inference /v1) endpoint + key (the API_SERVER_KEY configured in Hermes).
HERMES_BASE_URL=http://127.0.0.1:8642/v1
HERMES_API_KEY=

# Management (control plane) endpoint. On a loopback URL Hermes serves /api/*
# without auth; on a non-loopback URL supply a token.
HERMES_ADMIN_URL=http://127.0.0.1:9119
# auto | none | bearer | cookie | session  (session = X-Hermes-Session-Token; needed for the model catalog & switching)
HERMES_ADMIN_AUTH=auto
# Bearer token or session cookie value (only needed for non-loopback URLs).
HERMES_ADMIN_TOKEN=

# --- Ollama (optional) --------------------------------------------------
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODELS=llama3.1,qwen2.5

# --- OpenRouter (optional) ----------------------------------------------
# OPENROUTER_API_KEY=
# OPENROUTER_MODELS=openai/gpt-4o-mini,anthropic/claude-3.5-sonnet

# --- OpenAI (optional) --------------------------------------------------
# OPENAI_API_KEY=
# OPENAI_MODELS=gpt-4o-mini,gpt-4o

# --- Anthropic (optional) -----------------------------------------------
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODELS=claude-sonnet-4-6,claude-opus-4-8

# Public URL of this app (used for OpenRouter referer header).
APP_URL=http://localhost:3000
